+    });
+}
+
+async function testBinaryWrite() {
+    console.log('testBinaryWrite');
+    await withTempDir(async (dir) => {
+        const target = path.join(dir, 'img.bin');
+        const buf = Buffer.from([0, 1, 2, 3, 4, 0xff, 0xfe, 0xfd]);
