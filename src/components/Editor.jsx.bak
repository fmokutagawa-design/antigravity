import React, { useRef, useImperativeHandle, forwardRef, useState, useEffect, useLayoutEffect } from 'react';
import HighlightOverlay from './HighlightOverlay';
import '../index.css';

const Editor = forwardRef(({
  value,
  onChange,
  settings,
  onSave,
  isVertical,
  onOpenLink,
  availableTags,
  allFiles = [],
  onCursorChange // Add this
}, ref) => {
  const textareaRef = useRef(null);
  const [showAutocomplete, setShowAutocomplete] = useState(false);
  const [autocompletePosition, setAutocompletePosition] = useState({ top: 0, left: 0 });
  const [filterText, setFilterText] = useState('');
  const [selectedIndex, setSelectedIndex] = useState(0);
  const rulerRef = useRef(null); // Ref for the ruler container
  const overlayRef = useRef(null); // Ref for HighlightOverlay

  // Scrollbar Compensation
  const [sbSize, setSbSize] = useState(0);
  useLayoutEffect(() => {
    if (textareaRef.current) {
      const measure = () => {
        const val = settings.isVertical
          ? textareaRef.current.offsetHeight - textareaRef.current.clientHeight
          : textareaRef.current.offsetWidth - textareaRef.current.clientWidth;
        if (val >= 0 && val !== sbSize) setSbSize(val);
      };
      measure();
      const ro = new ResizeObserver(measure);
      ro.observe(textareaRef.current);
      return () => ro.disconnect();
    }
  }, [settings.isVertical, sbSize]); // Depend on vertical mode

  // CRITICAL: Scrollbar & Metric Sync State
  const [scrollbarWidth, setScrollbarWidth] = useState(0);
  // --- Measured Metrics for Pixel-Perfect Grid Sync ---
  const [measuredMetrics, setMeasuredMetrics] = useState(null);
  const measureRef = useRef(null);

  // AUDIT: Verify Computed vs Calculated Metrics & Wait for Font Load
  useEffect(() => {
    document.fonts.ready.then(() => {
      const ta = textareaRef.current;
      if (ta) {
        const fnMeasure = () => {
          // 1. Measure Scrollbar (Native width vs Client width)
          const w = ta.offsetWidth - ta.clientWidth;
          if (w !== scrollbarWidth) setScrollbarWidth(w);

          // Measure Real Metrics
          const cs = window.getComputedStyle(ta);

          // Measure Pitch from Ghost
          let pitchVal = parseFloat(cs.fontSize) || 16;
          if (measureRef.current) {
            const mRect = measureRef.current.getBoundingClientRect();
            const size = settings.isVertical ? mRect.height : mRect.width;
            if (size > 10) { // Ensure reasonable size
              pitchVal = size / 10;
            }
          }
          const pitchStr = pitchVal.toFixed(3) + "px";

          // Only update if different to avoid potential loops (though dependency array protects mostly)
          if (!measuredMetrics || measuredMetrics.fs !== cs.fontSize || measuredMetrics.lh !== cs.lineHeight || measuredMetrics.pitch !== pitchStr) {
            setMeasuredMetrics({
              fs: cs.fontSize,
              lh: cs.lineHeight,
              pitch: pitchStr
            });
            console.log('[Grid Sync] Calibrated:', pitchStr, cs.lineHeight);
          }
        };
        fnMeasure();

        // 2. Audit Metrics (Check for Double Standard)
        const style = window.getComputedStyle(ta);
        console.log('%c[Layout Audit] Font Ready', 'color: #00ff00; font-weight: bold;', {
          computedFS: style.fontSize,
          computedLH: style.lineHeight,
          computedFont: style.fontFamily,
          clientW: ta.clientWidth,
          offsetW: ta.offsetWidth,
          scrollbarW: ta.offsetWidth - ta.clientWidth
        });

        const ro = new ResizeObserver(fnMeasure);
        ro.observe(ta);
        return () => ro.disconnect();
      }
    });
  }, [settings.fontSize, settings.fontFamily, settings.lineHeight]);

  // Box Selection State
  const [boxSelection, setBoxSelection] = useState({ active: false, start: null, end: null });

  // Smart Reference State
  const [activeReference, setActiveReference] = useState(null); // { name, content, rect }
  const hoverTimeout = useRef(null);

  // Undo/Redo History
  // We use Refs to avoid re-renders impacting typing performance
  const history = useRef([]);
  const historyPtr = useRef(-1);
  const lastSaveTime = useRef(0);
  const isUndoing = useRef(false);
  const pendingSave = useRef(null);
  const wrapperRef = useRef(null); // Ref for wrapper to apply snap

  // --- Grid Snapping Logic (Masking Limit) ---
  React.useLayoutEffect(() => {
    if (settings.paperStyle !== 'grid' && settings.paperStyle !== 'manuscript') {
      // Cleanup if switching away
      if (wrapperRef.current) {
        wrapperRef.current.style.removeProperty('--snap-limit');
      }
      return;
    }

    const wrapper = wrapperRef.current;
    if (!wrapper) return;

    // --- FIX: Enforce Layout Parity & Grid Classes via JS to bypass Render issues ---
    if (settings.paperStyle) wrapper.classList.add(settings.paperStyle);

    if (textareaRef.current) {
      // Nuclear Reset
      const s = textareaRef.current.style;
      s.position = 'absolute';
      s.top = '0'; s.left = '0';
      s.width = '100%'; s.height = '100%';
      s.resize = 'none';
      s.zIndex = '1';

      // Force Red Color with Priority
      s.setProperty('color', 'rgba(255, 0, 0, 0.5)', 'important');
      s.setProperty('caret-color', 'red', 'important');
      s.setProperty('opacity', '1', 'important');

      console.log('[DEBUG] Applied Forced Red Style:', s.color);
    }

    const snapResize = () => {
      // Re-check inside callback
      if (settings.paperStyle !== 'grid' && settings.paperStyle !== 'manuscript') return;

      const parentCallback = () => {
        const rect = wrapper.getBoundingClientRect();
        // Computed padding
        const style = window.getComputedStyle(wrapper);
        const padTop = parseFloat(style.paddingTop) || 0;
        const padBot = parseFloat(style.paddingBottom) || 0;
        const padLeft = parseFloat(style.paddingLeft) || 0;
        const padRight = parseFloat(style.paddingRight) || 0;

        const contentW = rect.width - padLeft - padRight;
        const contentH = rect.height - padTop - padBot;

        const fSize = settings.fontSize || 16;
        const lHeightRatio = settings.lineHeight || 1.6;

        if (settings.isVertical) {
          // Vertical Mode: Snap WIDTH
          const tileW = fSize * lHeightRatio;
          if (tileW <= 0) return;

          const visibleCols = Math.floor(contentW / tileW);
          const limit = visibleCols * tileW;

          // Set Variable for CSS Mask
          // Note: In Vertical RL, background starts from Right.
          // Mask should be "transparent" from Right 0 to Limit, then "mask-color" from Limit to End.
          // CSS Gradient: `to left, transparent limit, color limit`
          wrapper.style.setProperty('--snap-limit', `${limit}px`);

        } else {
          // Horizontal Mode: Snap HEIGHT
          const tileH = fSize * lHeightRatio;
          if (tileH <= 0) return;

          const visibleRows = Math.floor(contentH / tileH);
          const limit = visibleRows * tileH;

          // CSS Gradient: `to bottom, transparent limit, color limit`
          wrapper.style.setProperty('--snap-limit', `${limit}px`);
        }
      };

      requestAnimationFrame(parentCallback);
    };

    const observer = new ResizeObserver(snapResize);
    observer.observe(wrapper);

    // Initial call
    snapResize();

    return () => {
      observer.disconnect();
      if (wrapper) wrapper.style.removeProperty('--snap-limit');
    };
  }, [settings.paperStyle, settings.isVertical, settings.fontSize, settings.lineHeight]);


  // Initialize history with initial value
  useEffect(() => {
    if (history.current.length === 0 && value) {
      history.current.push(value);
      historyPtr.current = 0;
    }
  }, []); // Run once or when logical dependency would reset? 
  // Actually, if we switch files, we might want to reset? 
  // Ideally, Editor should be keyed by file in App.jsx.

  const saveToHistory = (newValue, immediate = false) => {
    const now = Date.now();
    const timeSinceLast = now - lastSaveTime.current;

    // If undoing, don't save
    if (isUndoing.current) return;

    // Logic: 
    // If immediate (e.g. big action like paste/insert): push new state.
    // If typing (rapid updates): debounce or update tip.

    if (immediate || timeSinceLast > 1000) {
      // Commit previous pending if exists?
      // New Snapshot
      history.current.push(newValue);
      historyPtr.current++;
      lastSaveTime.current = now;
    } else {
      // Update current tip (merge changes)
      // Exception: If we just branched (redo path clearing), we must push.
      if (historyPtr.current < history.current.length - 1) {
        history.current = history.current.slice(0, historyPtr.current + 1);
        history.current.push(newValue);
        historyPtr.current++;
        lastSaveTime.current = now;
      } else {
        // Just update the tip
        history.current[history.current.length - 1] = newValue;
      }
    }
  };

  // NORMALIZE Tabs to Spaces for Grid Stability
  // NORMALIZE Tabs to Spaces for Grid Stability
  const sanitizeInput = (text) => {
    // Replace tabs with 2 spaces (matching CSS tab-size)
    // Also consider replacing Half-width with Full-width?
    return text.replace(/\t/g, '  ');
  };

  // Capture value changes from parent (e.g. typing handling in App that feeds back here)
  useEffect(() => {
    // This runs whenever `value` prop changes.
    // We need to distinguish between "User Typed" (handled by onChange -> saveToHistory)
    // and "Undo/Redo applied by App" (if App handled it) - but here Editor handles it.
    // AND "File Switch" (Value changed completely).

    // Simple heuristic for now: Just track it.
    // Ideally we trigger save logic inside the handleInput/insert functions, but simple tracking works too.
    if (!isUndoing.current) {
      saveToHistory(value);
    }
  }, [value]);

  const undo = () => {
    if (historyPtr.current > 0) {
      isUndoing.current = true;
      historyPtr.current--;
      const prevValue = history.current[historyPtr.current];
      onChange(prevValue);
      // Allow loop to finish before resetting flag
      setTimeout(() => isUndoing.current = false, 0);
    }
  };

  const redo = () => {
    if (historyPtr.current < history.current.length - 1) {
      isUndoing.current = true;
      historyPtr.current++;
      const nextValue = history.current[historyPtr.current];
      onChange(nextValue);
      setTimeout(() => isUndoing.current = false, 0);
    }
  };

  // Use CSS variables for size/height to support specific paper styles (Grid etc)
  const style = {
    fontFamily: settings.fontFamily,
  };

  // FIlter files... (keep existing)
  const filteredFiles = allFiles.filter(file =>
    file.name.toLowerCase().includes(filterText.toLowerCase()) &&
    !file.name.startsWith('.')
  ).slice(0, 10);

  // ... (keep insertRuby, insertText)
  const insertRuby = () => {
    const textarea = textareaRef.current;
    if (!textarea) return;

    const start = textarea.selectionStart;
    const end = textarea.selectionEnd;
    const selectedText = value.substring(start, end);

    const insertion = selectedText ? `｜${selectedText}《》` : '｜《》';
    const newText = value.substring(0, start) + insertion + value.substring(end);

    // Immediate save for structural change
    saveToHistory(newText, true);

    const scrollTop = textarea.scrollTop;
    const scrollLeft = textarea.scrollLeft;

    onChange(newText);

    setTimeout(() => {
      const newCursorPos = start + insertion.length - 1;
      textarea.focus();
      textarea.setSelectionRange(newCursorPos, newCursorPos);
      textarea.scrollTop = scrollTop;
      textarea.scrollLeft = scrollLeft;
    }, 0);
  };

  const insertText = (insertion) => {
    const textarea = textareaRef.current;
    if (!textarea) return;

    const start = textarea.selectionStart;
    const end = textarea.selectionEnd;

    const newText = value.substring(0, start) + insertion + value.substring(end);

    saveToHistory(newText, true);

    const scrollTop = textarea.scrollTop;
    const scrollLeft = textarea.scrollLeft;

    onChange(newText);

    setTimeout(() => {
      const newCursorPos = start + insertion.length;
      textarea.focus();
      textarea.setSelectionRange(newCursorPos, newCursorPos);
      textarea.scrollTop = scrollTop;
      textarea.scrollLeft = scrollLeft;
    }, 0);
  };

  const handleInput = (e) => {
    // Normal typing will trigger useEffect[value] -> saveToHistory(text, false)
    // We don't need explicit save here unless we want tighter control.

    const textarea = textareaRef.current;
    let cursor = textarea.selectionStart;
    let text = e.target.value;

    // Auto-Correct Half-Width Chars to Full-Width in Vertical Mode
    // This prevents "sideways space" and "sideways/stacked brackets".
    // Auto-Correct Half-Width Chars to Full-Width in Vertical Mode
    // Update: ONLY Space. Brackets should remain half-width to allow rotation (Mixed mode).
    if (settings.isVertical && cursor > 0) {
      const char = text[cursor - 1];
      let replacement = null;

      if (char === ' ') replacement = '　';

      if (replacement) {
        const before = text.substring(0, cursor - 1);
        const after = text.substring(cursor);
        text = before + replacement + after;

        // Update Parent State
        onChange(text);
        emitCursorStats(); // Update stats on content change
        emitCursorStats(); // Update stats on content change
        emitCursorStats(); // Update stats on content change

        // Fix Cursor
        setTimeout(() => {
          if (textareaRef.current) {
            textareaRef.current.setSelectionRange(cursor, cursor);
          }
        }, 0);
      }
    } // Continue with 'text'

    // Check for [[ trigger... (keep existing)
    const textBefore = text.substring(0, cursor);
    const lastOpen = textBefore.lastIndexOf('[[');

    if (lastOpen !== -1) {
      const textBetween = textBefore.substring(lastOpen + 2);
      if (!textBetween.includes(']]') && !textBetween.includes('\n')) {
        setFilterText(textBetween);
        setShowAutocomplete(true);
        setSelectedIndex(0);

        const rect = textarea.getBoundingClientRect();
        setAutocompletePosition({
          top: rect.top + 100,
          left: rect.left + 100
        });
        return;
      }
    }

    setShowAutocomplete(false);

    // Trigger Smart Reference Check
    if (hoverTimeout.current) clearTimeout(hoverTimeout.current);
    hoverTimeout.current = setTimeout(() => {
      checkSmartReference(textarea, textarea.selectionStart);
    }, 500);
  };

  const checkSmartReference = (textarea, cursorIndex) => {
    if (!allFiles || allFiles.length === 0) return;

    const text = textarea.value;
    // Check window around cursor to avoid scanning huge text for performance
    const range = 30; // 30 chars radius
    const startScan = Math.max(0, cursorIndex - range);
    const endScan = Math.min(text.length, cursorIndex + range);
    const snippet = text.substring(startScan, endScan);

    // Normalize Helper: Full SP -> Half SP (for robust matching)
    const normalize = (s) => s.replace(/　/g, ' ');
    const normSnippet = normalize(snippet);

    // Relative cursor position in snippet
    const relCursor = cursorIndex - startScan;

    // Find all files that appear in the snippet AND overlap the cursor
    const matches = allFiles.filter(f => {
      const fname = f.name.replace(/\.[^/.]+$/, "");
      if (!fname) return false;
      const normName = normalize(fname);
      if (normName.length < 2) return false; // Ignore single chars to avoid noise

      // Check if name exists in snippet
      // Note: A name might appear multiple times. We need to check if ANY instance overlaps cursor.
      // Simple heuristic: indexOf might return first instance. If cursor is on second, it fails.
      // Better: regex match? Or simple loop.
      let idx = normSnippet.indexOf(normName);
      while (idx !== -1) {
        if (relCursor >= idx && relCursor <= idx + normName.length) {
          return true;
        }
        idx = normSnippet.indexOf(normName, idx + 1);
      }
      return false;
    });

    if (matches.length > 0) {
      // Pick longest match (e.g. "Full Name" over "Full" or "Name")
      matches.sort((a, b) => {
        const wa = a.name.replace(/\.[^/.]+$/, "").length;
        const wb = b.name.replace(/\.[^/.]+$/, "").length;
        return wb - wa;
      });
      const best = matches[0];
      const fname = best.name.replace(/\.[^/.]+$/, "");

      setActiveReference({
        name: fname,
        file: best,
        content: best.body || best.content || "(No content)"
      });
    } else {
      setActiveReference(null);
    }
  };

  // --- Helpers for Status Bar & Utilities ---
  const calculateLineCol = (text, position) => {
    const textBefore = text.substring(0, position);
    const lines = textBefore.split('\n');
    const row = lines.length;
    const col = lines[lines.length - 1].length + 1;
    return { row, col };
  };

  // Emit stats whenever text or cursor changes
  const emitCursorStats = () => {
    if (!onCursorChange) return;
    const textarea = textareaRef.current;
    if (!textarea) return;

    const { selectionStart } = textarea;
    const { row, col } = calculateLineCol(value, selectionStart);

    // Character Code logic
    const charCode = value.charCodeAt(selectionStart);
    const charCodeHex = isNaN(charCode) ? '-' : `U+${charCode.toString(16).toUpperCase().padStart(4, '0')}`;

    onCursorChange({ row, col, charCodeHex });
  };

  // --- Sakura Utilities ---
  const insertDateCheck = () => {
    const now = new Date();
    const str = `${now.getFullYear()}/${(now.getMonth() + 1).toString().padStart(2, '0')}/${now.getDate().toString().padStart(2, '0')}`;
    insertText(str);
  };

  const insertTimeCheck = () => {
    const now = new Date();
    const str = `${now.getHours().toString().padStart(2, '0')}:${now.getMinutes().toString().padStart(2, '0')}:${now.getSeconds().toString().padStart(2, '0')}`;
    insertText(str);
  };

  const sortLines = (asc) => {
    const textarea = textareaRef.current;
    if (!textarea) return;
    const start = textarea.selectionStart;
    const end = textarea.selectionEnd;
    if (start === end) return;
    const text = textarea.value;
    const selectedText = text.substring(start, end);
    const lines = selectedText.split('\n');
    lines.sort((a, b) => {
      if (asc) return a.localeCompare(b, 'ja');
      else return b.localeCompare(a, 'ja');
    });
    const newText = lines.join('\n');
    document.execCommand('insertText', false, newText);
  };

  const trimLines = (isLeft) => {
    const textarea = textareaRef.current;
    if (!textarea) return;
    const start = textarea.selectionStart;
    const end = textarea.selectionEnd;
    let targetStart = start;
    let targetEnd = end;
    let isSingleLine = start === end;
    let text = textarea.value;
    if (isSingleLine) {
      let lineStart = text.lastIndexOf('\n', start - 1) + 1;
      let lineEnd = text.indexOf('\n', start);
      if (lineEnd === -1) lineEnd = text.length;
      targetStart = lineStart;
      targetEnd = lineEnd;
    }
    const selectedText = text.substring(targetStart, targetEnd);
    const lines = selectedText.split('\n');
    const processed = lines.map(line => {
      if (isLeft) return line.trimStart();
      else return line.trimEnd();
    });
    const newText = processed.join('\n');
    if (isSingleLine) {
      textarea.setSelectionRange(targetStart, targetEnd);
    }
    document.execCommand('insertText', false, newText);
  };

  // Line Operations Logic
  const deleteCurrentLine = () => {
    const textarea = textareaRef.current;
    if (!textarea) return;
    const start = textarea.selectionStart;
    const text = textarea.value;

    const before = text.substring(0, start);
    const after = text.substring(start);

    const lineStart = before.lastIndexOf('\n') + 1;
    let lineEnd = text.indexOf('\n', start);
    if (lineEnd === -1) lineEnd = text.length;
    else lineEnd += 1; // Include newline

    const newText = text.substring(0, lineStart) + text.substring(lineEnd);
    saveToHistory(newText, true);
    onChange(newText);

    setTimeout(() => {
      textarea.setSelectionRange(lineStart, lineStart);
    }, 0);
  };

  const moveCurrentLine = (direction) => {
    const textarea = textareaRef.current;
    if (!textarea) return;
    const start = textarea.selectionStart;
    const text = textarea.value;
    const lines = text.split('\n');

    const before = text.substring(0, start);
    const currentLineIndex = before.split('\n').length - 1;

    if (direction === -1 && currentLineIndex === 0) return;
    if (direction === 1 && currentLineIndex === lines.length - 1) return;

    const lineToMove = lines[currentLineIndex];
    const targetIndex = currentLineIndex + direction;

    // Swap
    lines.splice(currentLineIndex, 1);
    lines.splice(targetIndex, 0, lineToMove);

    const newText = lines.join('\n');
    saveToHistory(newText, true);
    onChange(newText);

    // Restore cursor: Need to calculate new position
    // Simple heuristic: Move cursor by length of swapped line?
    // Actually, if we just count chars up to targetIndex...
    setTimeout(() => {
      let newPos = 0;
      for (let i = 0; i < targetIndex; i++) newPos += lines[i].length + 1;
      // Keep relative offset within line?
      const offsetInLine = start - (before.lastIndexOf('\n') + 1);
      newPos += Math.min(offsetInLine, lines[targetIndex].length);

      textarea.setSelectionRange(newPos, newPos);
    }, 0);
  };

  const duplicateCurrentLine = (direction) => {
    const textarea = textareaRef.current;
    if (!textarea) return;
    const start = textarea.selectionStart;
    const text = textarea.value;
    const lines = text.split('\n');

    const before = text.substring(0, start);
    const currentLineIndex = before.split('\n').length - 1;

    const lineToCopy = lines[currentLineIndex];
    // Insert duplicate below (standard) or above? 
    // VSCode Shift+Alt+Up -> Duplicate Up, Down -> Duplicate Down
    const insertIndex = direction === -1 ? currentLineIndex : currentLineIndex + 1;

    lines.splice(insertIndex, 0, lineToCopy);

    const newText = lines.join('\n');
    saveToHistory(newText, true);
    onChange(newText);

    setTimeout(() => {
      // If duplicated down, cursor stays. If up, cursor moves down?
      // VSCode: 
      // Down: duplicate appears below, cursor stays on original (now top).
      // Up: duplicate appears above, cursor stays on original (now bottom)? Or moves to new?
      // Actually VSCode duplicates and KEEPS CURSOR on the resulting line in the direction.
      // Let's keep it simple: we just add the line. Cursor stays?
      // If we insert at currentLineIndex (Up), everything shifts down. Cursor should shift.
      if (direction === -1) {
        const shift = lineToCopy.length + 1;
        textarea.setSelectionRange(start + shift, start + shift);
      } else {
        textarea.setSelectionRange(start, start);
      }
    }, 0);
  };

  // Trigger on click/select too
  const handleSelect = (e) => {
    handleInput(e);
    emitCursorStats();
  };


  const handleKeyDown = (e) => {
    // Box Selection Intercept
    if (boxSelection.active) {
      if (e.key === 'Backspace' || e.key === 'Delete') {
        e.preventDefault();
        deleteBoxSelection();
        return;
      }
      if (e.key.length === 1 && !e.ctrlKey && !e.metaKey && !e.altKey) {
        e.preventDefault();
        insertBoxText(e.key);
        return;
      }
    }

    // Undo/Redo Shortcuts
    if ((e.metaKey || e.ctrlKey) && e.key === 'z') {
      e.preventDefault();
      if (e.shiftKey) {
        redo();
      } else {
        undo();
      }
      return;
    }
    // Line Operations (Sakura/VSCode Style)
    // 1. Delete Line: Cmd+Shift+K (Mac VSCode), Ctrl+Shift+K (Win/Sakura), Ctrl+L (Sublime)
    if ((e.metaKey && e.shiftKey && e.key === 'k') ||
      (e.ctrlKey && e.shiftKey && e.key === 'k') ||
      (e.ctrlKey && !e.shiftKey && !e.altKey && e.key === 'l')) {
      e.preventDefault();
      deleteCurrentLine();
      return;
    }

    // 2. Move Line: Alt+Up/Down
    if (e.altKey && !e.shiftKey && (e.key === 'ArrowUp' || e.key === 'ArrowDown')) {
      e.preventDefault();
      moveCurrentLine(e.key === 'ArrowUp' ? -1 : 1);
      return;
    }

    // 3. Duplicate Line: Alt+Shift+Up/Down (VSCode) OR Ctrl+Down (Sakura)
    if ((e.altKey && e.shiftKey && (e.key === 'ArrowUp' || e.key === 'ArrowDown')) ||
      (e.ctrlKey && !e.shiftKey && !e.altKey && !e.metaKey && e.key === 'ArrowDown')) {
      e.preventDefault();
      const dir = (e.key === 'ArrowUp') ? -1 : 1;
      duplicateCurrentLine(dir);
      return;
    }

    // Redo alternative (Ctrl+Y)
    if ((e.metaKey || e.ctrlKey) && e.key === 'y') {
      e.preventDefault();
      redo();
      return;
    }

    if (showAutocomplete) {
      if (e.nativeEvent.isComposing) return; // Skip if using IME
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setSelectedIndex(prev => (prev + 1) % filteredFiles.length);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setSelectedIndex(prev => (prev - 1 + filteredFiles.length) % filteredFiles.length);
      } else if (e.key === 'Enter' || e.key === 'Tab') {
        e.preventDefault();
        if (filteredFiles.length > 0) {
          selectSuggestion(filteredFiles[selectedIndex]);
        }
      } else if (e.key === 'Escape') {
        setShowAutocomplete(false);
      }
    }
    // --- Sakura Editor Like Utilities ---
    // Date/Time
    if (e.altKey && e.key === ';') { e.preventDefault(); insertDateCheck(); } // Alt+; Date
    if (e.altKey && e.key === ':') { e.preventDefault(); insertTimeCheck(); } // Alt+: Time

    // Sort
    if (e.altKey && (e.key === 'a' || e.key === 'A')) { e.preventDefault(); sortLines(true); } // Alt+A Asc
    if (e.altKey && (e.key === 'd' || e.key === 'D')) { e.preventDefault(); sortLines(false); } // Alt+D Desc

    // Trim
    if (e.altKey && (e.key === 'l' || e.key === 'L')) { e.preventDefault(); trimLines(true); } // Alt+L Left Trim
    if (e.altKey && (e.key === 'r' || e.key === 'R')) { e.preventDefault(); trimLines(false); } // Alt+R Right Trim

    // Update stats on navigation
    if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'Home', 'End', 'PageUp', 'PageDown'].includes(e.key)) {
