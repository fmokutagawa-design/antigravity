        // Font Shaping Parity
        fontKerning: 'none',
        fontVariantLigatures: 'none',

        minHeight: 0,
        overflow: 'hidden' /* Ensure exact box match */
      }}
    >
      {/* Ruler Component */}

      {/* Ruler - Hide in Vertical Mode */}
      {!settings.isVertical && (
        <div className="editor-ruler" ref={rulerRef} style={{
          gridRow: '2', // Explicitly place in bottom row
          gridColumn: '1',
          height: '24px',
          background: '#fcfcfc',
          borderBottom: '1px solid #e0e0e0',
          display: 'flex',
          alignItems: 'flex-end',
          paddingLeft: '10px',
          overflow: 'hidden',
          userSelect: 'none'
        }}>
          <div style={{ position: 'relative', width: '100%', height: '100%' }}>
            {Array.from({ length: 100 }).map((_, i) => {
              const n = (i + 1) * 10;
              return (
                <div key={n} style={{
                  position: 'absolute',
                  left: `${n * (settings.fontSize || 16) * 0.6}px`, // Approx char width
                  bottom: '0',
                  height: '50%',
                  borderLeft: '1px solid #ccc',
                  fontSize: '10px',
                  color: '#999',
                  paddingLeft: '2px'
                }}>
                  {n % 50 === 0 && n}
                </div>
              );
            })}
          </div>
        </div>
      )}

      {/* Box Selection Overlay */}
      {/* Box Selection Overlay - Safe Render */
        boxSelection.active && boxSelection.start && boxSelection.end && textareaRef.current && (
          <div style={{
            position: 'absolute',
            zIndex: 20,
            pointerEvents: 'none',
            background: 'rgba(0, 120, 215, 0.3)',
            border: '1px solid rgba(0, 120, 215, 0.8)',
            left: (Math.min(boxSelection.start.visualX, boxSelection.end.visualX) - (textareaRef.current?.scrollLeft || 0) + 32) + 'px',
            top: (Math.min(boxSelection.start.visualY, boxSelection.end.visualY) - (textareaRef.current?.scrollTop || 0) + 32) + 'px',
            width: Math.abs(boxSelection.end.visualX - boxSelection.start.visualX) + 'px',
            height: Math.abs(boxSelection.end.visualY - boxSelection.start.visualY) + 'px'
          }} />
        )}

      {/* RESTORED HIGHLIGHT OVERLAY - Conditional Rendering */}
      {/*
          CRITICAL FIX: Only render Overlay if Syntax Highlighting is ENABLED.
          For Monochrome mode, we use NATIVE textarea rendering.
          This guarantees 0% drift, perfect scrolling, and max performance.
      */}
      {settings.editorSyntaxColors !== false && (
        <HighlightOverlay
          ref={overlayRef}
          text={value}
          settings={settings}
          // Use identical classes to ensure CSS inheritance (padding, borders, etc) matches Textarea
          className={`${settings.isVertical ? "vertical-editor" : "horizontal-editor"} ${settings.showGrid !== false ? 'grid-mode' : ''} highlight-overlay`}
          style={{
            ...style,
            ...dimStyle,
            // CRITICAL: Clear inline background props to allow CSS Grid/Lines to render
            background: undefined,
            backgroundImage: undefined,
            backgroundColor: undefined,

            // Force Visible Text (Override dimStyle.color='transparent')
            color: settings.colorTheme === 'dark' ? '#eee' : '#111',

            // --- CRITICAL: FORCE EXACT SYNC WITH TEXTAREA ---
            // Use Exact Pixel Values derived from rounding logic
            fontSize: 'var(--editor-font-size)',
            lineHeight: 'var(--editor-line-height)',

            // Strict Typography
            letterSpacing: '0px',
            wordSpacing: '0px',

            // Directions
            writingMode: settings.isVertical ? 'vertical-rl' : 'horizontal-tb',
            direction: 'ltr',

            // CSS Variables (Single Source of Truth - Method A)
            fontFamily: 'var(--editor-font-family)',

            // Layout
            boxSizing: 'border-box',
            border: 'none',
            margin: '0',
            // Padding Parity: Match Textarea exactly (No manual sbSize comp)
            paddingTop: 'var(--editor-line-height)',
            paddingLeft: 'var(--editor-line-height)',
            paddingBottom: 'var(--editor-line-height)',
            paddingRight: 'var(--editor-line-height)',
            overflow: 'scroll', // Ensure scrollbar reservation matches Textarea
          }}
          disableColors={settings.editorSyntaxColors === false}
        />
      )}

      <textarea
        ref={textareaRef}
        // ONLY use transparent-force if Overlay is active
        className={`${settings.isVertical ? "vertical-editor" : "horizontal-editor"} ${settings.showGrid !== false ? 'grid-mode' : ''} ${settings.editorSyntaxColors !== false ? 'transparent-force' : ''}`}
        style={{
          ...style,
          ...dimStyle,
          // Explicitly clear 'background' shorthand to prevent conflicts/react warnings
          background: undefined,

          zIndex: 1, // Ensure Textarea is ABOVE highlight overlay
          position: 'relative', // Needed for zIndex

          // --- Layout Overrides ---
          // Enforce synced metrics to ensure Background (Pixel) matches Text (Pixel)
          fontSize: 'var(--editor-font-size)',
          lineHeight: 'var(--editor-line-height)',
          fontFamily: 'var(--editor-font-family)', // CRITICAL: Sync with Overlay

          letterSpacing: '0px',
          wordSpacing: '0px',

          boxSizing: 'border-box',
          border: 'none',
          margin: '0',
          // Fix React Padding Warning
          paddingTop: 'var(--editor-line-height)',
          paddingBottom: 'var(--editor-line-height)',
          paddingLeft: 'var(--editor-line-height)',
          paddingRight: 'var(--editor-line-height)',
          overflow: 'scroll', // CHANGED from 'auto' to 'scroll' for strict width parity

          // Force Directions
          writingMode: settings.isVertical ? 'vertical-rl' : 'horizontal-tb',
          direction: 'ltr',

          // --- Background System (Consolidated) ---
          // For Manuscript: Delegate to CSS (Complex Gap/Rail/Rung system)
          // For Others: Use Simple Inline Grid if showGrid is true
          ...(settings.paperStyle !== 'manuscript' ? {
            backgroundImage: settings.showGrid
              ? `linear-gradient(to right, ${lineColor} 1px, transparent 1px), linear-gradient(to bottom, ${lineColor} 1px, transparent 1px)`
              : 'none',
            backgroundPosition: settings.isVertical ? 'right top' : 'left top',
            backgroundAttachment: 'local',
            backgroundOrigin: 'content-box',
            backgroundRepeat: 'repeat',
            backgroundSize: settings.showGrid
              ? (settings.isVertical
                // Back to PIXELS. 1lh support is spotty in some environments.
                ? `${pxLineHeightStr} ${roundedFontSize}px`
                : `${roundedFontSize}px ${pxLineHeightStr}`)
              : 'auto',
          } : {}),
        }}
        value={value}
        onChange={(e) => {
          // Normalize Tabs immediately to prevent layout drift
          const cleanVal = sanitizeInput(e.target.value);
          onChange(cleanVal);
          handleInput(e);
        }}
        onScroll={handleScroll}
        onWheel={(e) => {
          if (settings.isVertical && textareaRef.current) {
            // Force Horizontal Scroll from Vertical Wheel
            if (e.deltaY !== 0) {
              // e.preventDefault() might break inertia, but ensures we capture the event for X-axis.
              // We rely on scrollBy for native-like feel.
              textareaRef.current.scrollBy({ left: -e.deltaY, behavior: 'auto' });
            }
          }
        }}
        // onScroll handled above
        onSelect={handleSelect}
        onClick={handleSelect}
        onKeyUp={handleSelect}

        placeholder="ここから物語を紡ぎましょう..."
        spellCheck={false}
        onContextMenu={handleContextMenu}
        onMouseUp={handleMouseUpBox}
        onMouseDown={handleMouseDown}
        onMouseMove={handleMouseMove}
      />

      {/* Ghost Measurement Div for Auto-Calibration */}
      <div
        ref={measureRef}
        aria-hidden="true"
        className={`${settings.isVertical ? "vertical-editor" : "horizontal-editor"} ${settings.showGrid !== false ? 'grid-mode' : ''} ${settings.editorSyntaxColors !== false ? 'transparent-force' : ''}`}
        style={{
          ...dimStyle,
          position: 'absolute',
          top: -9999,
          left: -9999,
          visibility: 'hidden',
          pointerEvents: 'none',
          whiteSpace: 'pre', // No wrapping
          width: 'auto',
          height: 'auto',
          // Override line-height to ensure single line measurement isn't affected by block stacking?
          // Actually we measure the flow dimension.
        }}
      >
        ああああああああああ
      </div>

      {showAutocomplete && (
        <div
          className="autocomplete-popup"
          style={{
            position: 'absolute',
            top: '50%',
            left: '50%',
            transform: 'translate(-50%, -50%)',
            background: 'white',
            border: '1px solid #ccc',
            boxShadow: '0 4px 12px rgba(0,0,0,0.15)',
            borderRadius: '4px',
            zIndex: 1000,
            maxHeight: '200px',
            overflowY: 'auto',
            width: '250px'
          }}
        >
          <div style={{ padding: '4px 8px', background: '#f5f5f5', borderBottom: '1px solid #eee', fontSize: '0.75rem', color: '#666' }}>
            リンク先を選択 (Enterで決定)
          </div>
          {filteredFiles.length > 0 ? (
            filteredFiles.map((file, index) => (
              <div
                key={file.path}
                className={`autocomplete-item ${index === selectedIndex ? 'selected' : ''}`}
                onClick={() => selectSuggestion(file)}
                style={{
                  padding: '6px 10px',
                  cursor: 'pointer',
                  background: index === selectedIndex ? '#8e44ad' : 'transparent',
                  color: index === selectedIndex ? 'white' : '#333',
                  fontSize: '0.9rem'
                }}
              >
                {file.name.replace(/\.[^/.]+$/, "")}
              </div>
            ))
          ) : (
            <div style={{ padding: '8px', color: '#999', fontSize: '0.8rem', textAlign: 'center' }}>
              候補なし
            </div>
          )}
        </div>
      )}

      {/* Smart Reference Popup */}
      {activeReference && (
        <div
          className="smart-reference-popup"
          style={{
            position: 'absolute',
            bottom: '20px',
            right: '20px',
            width: '300px',
            maxHeight: '200px',
            background: 'rgba(255, 255, 255, 0.95)',
            backdropFilter: 'blur(5px)',
            border: '1px solid #ddd',
            boxShadow: '0 -4px 16px rgba(0,0,0,0.1)',
            borderRadius: '8px',
            padding: '12px',
            zIndex: 900,
            display: 'flex',
            flexDirection: 'column',
            gap: '8px',
            transition: 'opacity 0.2s'
          }}
        >
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', borderBottom: '1px solid #eee', paddingBottom: '4px' }}>
            <span style={{ fontWeight: 'bold', fontSize: '0.9rem' }}>📖 {activeReference.name}</span>
            <span style={{ fontSize: '0.7rem', color: '#888' }}>Auto-Ref</span>
          </div>
          <div style={{
            fontSize: '0.8rem',
            color: '#555',
            whiteSpace: 'pre-wrap',
            overflowY: 'auto',
            flex: 1,
            lineHeight: '1.4',
            maxHeight: '120px'
          }}>
            {activeReference.content.length > 200
              ? activeReference.content.substring(0, 200) + '...'
              : activeReference.content}
          </div>
          <button
            onClick={() => onOpenLink && onOpenLink(activeReference.name)}
            style={{
              padding: '6px',
              background: '#e3f2fd',
              color: '#1565c0',
              border: 'none',
              borderRadius: '44px',
              cursor: 'pointer',
              fontSize: '0.8rem',
              fontWeight: 'bold'
            }}
          >
            全体を開く
          </button>
        </div>
      )}

      {/* DEBUG METRICS */}
      <div style={{
        position: 'fixed', bottom: '10px', right: '10px',
        background: 'rgba(0,0,0,0.9)', color: '#0f0',
        padding: '10px', fontSize: '12px', fontFamily: 'monospace',
        zIndex: 10000, pointerEvents: 'none', border: '1px solid #0f0'
      }}>
        <div>FS: {dimStyle.fontSize}</div>
        <div>LH: {dimStyle.lineHeight}</div>
        <div>Pad: {dimStyle.padding}</div>
        <div>DPR: {typeof window !== 'undefined' ? window.devicePixelRatio : '?'}</div>
      </div>
    </div>
  );
});

Editor.displayName = 'Editor';

export default Editor;
