  const selectSuggestion = (file) => {
    const textarea = textareaRef.current;
    const cursor = textarea.selectionStart;
    const textBefore = value.substring(0, cursor);
    const lastOpen = textBefore.lastIndexOf('[[');

    if (lastOpen !== -1) {
      // Check for closing ]] after cursor to avoid duplication
      const textAfter = value.substring(cursor);
      const nextClose = textAfter.indexOf(']]');

      let endReplace = cursor;
      let suffix = textAfter;

      // If we find a closing bracket on the same line, consume it
      if (nextClose !== -1 && !textAfter.substring(0, nextClose).includes('\n')) {
        endReplace = cursor + nextClose + 2;
        suffix = value.substring(endReplace);
      }

      const prefix = value.substring(0, lastOpen);
      const linkText = `[[${file.name.replace(/\.[^/.]+$/, "")}]]`;

      const newText = prefix + linkText + suffix;
      onChange(newText);

      setShowAutocomplete(false);

      setTimeout(() => {
        const newCursor = lastOpen + linkText.length;
        textarea.focus();
        textarea.setSelectionRange(newCursor, newCursor);
      }, 0);
    }

    // --- Sakura Editor Like Utilities ---
    // Date/Time
    // Use Code to handle Mac Option key (prevents char masking 'semicolon' -> '…')
    if (e.altKey && (e.code === 'Semicolon' || e.key === ';')) { e.preventDefault(); insertDateCheck(); } // Alt+;
    if (e.altKey && (e.code === 'Quote' || e.key === ':' || e.key === '*')) { e.preventDefault(); insertTimeCheck(); } // Alt+: (US Quote is Shift+;, JP : is dedicated)

    // Sort
    if (e.altKey && (e.code === 'KeyA' || e.key === 'a' || e.key === 'A')) { e.preventDefault(); sortLines(true); } // Alt+A Asc
    if (e.altKey && (e.code === 'KeyD' || e.key === 'd' || e.key === 'D')) { e.preventDefault(); sortLines(false); } // Alt+D Desc

    // Trim
    if (e.altKey && (e.code === 'KeyL' || e.key === 'l' || e.key === 'L')) { e.preventDefault(); trimLines(true); } // Alt+L Left Trim
    if (e.altKey && (e.code === 'KeyR' || e.key === 'r' || e.key === 'R')) { e.preventDefault(); trimLines(false); } // Alt+R Right Trim

    // Update stats on navigation
    if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'Home', 'End', 'PageUp', 'PageDown'].includes(e.key)) {
      setTimeout(emitCursorStats, 0);
    }
  };



  const handleContextMenu = (e) => {
    e.preventDefault();
    const textarea = textareaRef.current;
    const { selectionStart, selectionEnd, value } = textarea;

    // Check for Wiki Link [[...]] under cursor
    const cursor = selectionStart;
    const text = value;
    let linkTarget = null;

    // Use regex to find all links, check if cursor is inside one
    const linkRegex = /\[\[(.*?)\]\]|［［(.*?)］］/g;
    let match;
    while ((match = linkRegex.exec(text)) !== null) {
      if (cursor >= match.index && cursor <= match.index + match[0].length) {
        // inside
        linkTarget = match[1] || match[2];
        break;
      }
    }

    // Create custom context menu
    const menu = document.createElement('div');
    menu.className = 'context-menu';

    let menuX = e.clientX;
    let menuY = e.clientY;
    const estWidth = 220;
    const estHeight = 350;

    // Adjust if clipping bottom/right
    if (menuY + estHeight > window.innerHeight) {
      menuY = window.innerHeight - estHeight - 10;
    }
    if (menuX + estWidth > window.innerWidth) {
      menuX = Math.max(0, menuX - estWidth);
    }

    menu.style.left = `${menuX}px`;
    menu.style.top = `${menuY}px`;

    // 1. Link Navigation
    if (linkTarget) {
      const linkItem = document.createElement('div');
      linkItem.className = 'context-menu-item';
      linkItem.innerText = `🔗 ${linkTarget} を開く`;
      linkItem.onclick = () => {
        if (onOpenLink) onOpenLink(linkTarget);
        document.body.removeChild(menu);
      };
      menu.appendChild(linkItem);

      const separator = document.createElement('div');
      separator.className = 'context-menu-separator';
      menu.appendChild(separator);
    }

    // 2. Tag Insertion (Removed per user request)
    // if (availableTags && availableTags.size > 0) { ... }

    // 3. Link Creation (Wrap selected text)
    if (selectionStart !== selectionEnd) {
      const linkCreateItem = document.createElement('div');
      linkCreateItem.className = 'context-menu-item';
      linkCreateItem.innerText = '🔗 リンク化';
      linkCreateItem.onclick = () => {
        const selectedText = value.substring(selectionStart, selectionEnd);
        insertText(`[[${selectedText}]]`);
        document.body.removeChild(menu);
      };
      menu.appendChild(linkCreateItem);
    }

    // Standard items
    const copyItem = document.createElement('div');
    copyItem.className = 'context-menu-item';
    copyItem.innerText = 'コピー';
    copyItem.onclick = () => {
      const selectedText = value.substring(selectionStart, selectionEnd);
      navigator.clipboard.writeText(selectedText);
      document.body.removeChild(menu);
    };
    menu.appendChild(copyItem);

    const pasteItem = document.createElement('div');
    pasteItem.className = 'context-menu-item';
    pasteItem.innerText = '貼り付け';
    pasteItem.onclick = async () => {
      const text = await navigator.clipboard.readText();
      insertText(text);
      document.body.removeChild(menu);
    };
    menu.appendChild(pasteItem);

    // Append to body
    document.body.appendChild(menu);

    // Better overlay approach
    const closeMenu = () => {
      if (document.body.contains(menu)) {
        document.body.removeChild(menu);
      }
      document.removeEventListener('click', closeMenu);
    };

    // We need to delay adding the listener so it doesn't trigger immediately
    setTimeout(() => {
      document.addEventListener('click', closeMenu);
    }, 0);
  };



