{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Antigravity",
  "version": "0.1.0",
  "identifier": "design.fmokutagawa.antigravity",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "title": "Antigravity",
    "windows": [
      {
        "title": "Antigravity",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "dialog": {},
    "fs": {
      "scope": {
        "allow": ["**"],
        "deny": []
      }
    },
    "shell": {
      "open": true
    }
  }
}
