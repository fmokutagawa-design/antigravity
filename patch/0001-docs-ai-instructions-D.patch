+    function expect(name, cond, detail) {
+        if (cond) { passed++; console.log(`  ✓ ${name}`); }
+        else { failed++; console.error(`  ✗ ${name}${detail ? ': ' + String(detail).slice(0, 200) : ''}`); }
+    }
+
+    // ... テスト関数定義（下記を実装）...
+
+    const tests = [
+        testSplitFileName,
